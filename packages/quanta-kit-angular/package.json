{
  "name": "quanta-kit-design-system-angular",
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "build": "npm run sync-version && ng-packagr -p projects/quanta-kit/ng-package.json",
    "sync-version": "node -e \"const pkg = require('./package.json'); const libPkg = require('./projects/quanta-kit/package.json'); libPkg.version = pkg.version; require('fs').writeFileSync('./projects/quanta-kit/package.json', JSON.stringify(libPkg, null, 2) + '\\n');\"",
    "watch": "ng-packagr -p projects/quanta-kit/ng-package.json --watch",
    "storybook": "ng run quanta-kit:storybook",
    "build-storybook": "ng run quanta-kit:build-storybook"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "overrides": {
    "tmp": "^0.2.4"
  },
  "private": false,
  "dependencies": {
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/router": "^21.1.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular/compiler-cli": "^21.1.5",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/angular": "^10.2.10",
    "ng-packagr": "^21.1.0",
    "storybook": "^10.2.10",
    "typescript": "~5.9.3"
  }
}
