{
  "name": "quanta-kit-design-system-angular",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/quanta-kit/fesm2022/quanta-kit-design-system-angular.mjs",
  "module": "dist/quanta-kit/fesm2022/quanta-kit-design-system-angular.mjs",
  "types": "dist/quanta-kit/types/quanta-kit-design-system-angular.d.ts",
  "exports": {
    ".": {
      "types": "./dist/quanta-kit/types/quanta-kit-design-system-angular.d.ts",
      "import": "./dist/quanta-kit/fesm2022/quanta-kit-design-system-angular.mjs",
      "default": "./dist/quanta-kit/fesm2022/quanta-kit-design-system-angular.mjs"
    }
  },
  "files": [
    "dist/quanta-kit"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marvin-aroza/quanta-kit-design-system",
    "directory": "packages/quanta-kit-angular"
  },
  "bugs": {
    "url": "https://github.com/marvin-aroza/quanta-kit-design-system/issues"
  },
  "homepage": "https://github.com/marvin-aroza/quanta-kit-design-system/tree/main/packages/quanta-kit-angular#readme",
  "scripts": {
    "ng": "ng",
    "build": "ng-packagr -p projects/quanta-kit/ng-package.json && npm run sync-dist-version",
    "sync-dist-version": "node -e \"const fs = require('fs'); const rootPkg = require('./package.json'); const distPath = './dist/quanta-kit/package.json'; if (fs.existsSync(distPath)) { const distPkg = JSON.parse(fs.readFileSync(distPath, 'utf8')); distPkg.version = rootPkg.version; fs.writeFileSync(distPath, JSON.stringify(distPkg, null, 2) + '\\n'); }\"",
    "watch": "ng-packagr -p projects/quanta-kit/ng-package.json --watch",
    "storybook": "ng run quanta-kit:storybook",
    "build-storybook": "ng run quanta-kit:build-storybook"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "overrides": {
    "tmp": "^0.2.4"
  },
  "private": false,
  "dependencies": {
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/router": "^21.1.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular/compiler-cli": "^21.1.5",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/angular": "^10.2.10",
    "karma-chrome-launcher": "^3.2.0",
    "karma-jasmine": "^5.1.0",
    "ng-packagr": "^21.1.0",
    "storybook": "^10.2.10",
    "typescript": "~5.9.3"
  }
}
