{
  "name": "quanta-kit-design-system-vue",
  "version": "0.0.4",
  "type": "module",
  "description": "Quanta Kit Vue Component Library",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    },
    "./dist/quanta-kit-design-system-vue.css": "./dist/quanta-kit-design-system-vue.css",
    "./dist/quanta-kit-vue.css": "./dist/quanta-kit-design-system-vue.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && npm run build:types",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "vue-tsc --noEmit",
    "storybook": "npx storybook dev -p 6008",
    "build-storybook": "npx storybook build"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/vue3-vite": "^10.2.19",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^17.3.0",
    "storybook": "^10.2.10",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.5"
  },
  "keywords": [
    "vue",
    "vue3",
    "components",
    "ui",
    "design-system",
    "quanta-kit"
  ],
  "author": "Marvin Aroza",
  "license": "MIT"
}
