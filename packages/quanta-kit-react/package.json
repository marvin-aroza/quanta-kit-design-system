{
  "name": "quanta-kit-design-system-react",
  "version": "0.0.4",
  "type": "module",
  "description": "Quanta Kit React Component Library",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:rollup && npm run build:types",
    "build:rollup": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "storybook": "npx storybook dev -p 6007",
    "build-storybook": "npx storybook build"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/parser": "^8.56.1",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/react-vite": "^10.2.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "globals": "^17.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.59.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10.2.10",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "quanta-kit"
  ],
  "author": "Marvin Aroza",
  "license": "MIT"
}
