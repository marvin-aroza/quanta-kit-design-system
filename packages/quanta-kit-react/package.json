{
  "name": "quanta-kit-design-system-react",
  "version": "0.0.2",
  "type": "module",
  "description": "Quanta Kit React Component Library",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:rollup && npm run build:types",
    "build:rollup": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "lint": "node -e \"console.log('lint skipped: TS parser removed during hard vulnerability reduction')\"",
    "lint:fix": "npm run lint",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.58.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "quanta-kit"
  ],
  "author": "Marvin Aroza",
  "license": "MIT"
}
