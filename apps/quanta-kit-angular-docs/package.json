    "@angular/platform-browser": "^21.1.5",
    "@angular/router": "^21.2.0",
    "quanta-kit-design-system-angular": "0.1.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "vitest": "^4.0.8",
    "typescript": "~5.9.3"
  }
