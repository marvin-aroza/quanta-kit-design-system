echo "Running pre-commit checks..."

if [ ! -d "node_modules" ]; then
  echo "node_modules is missing. Run: npm install"
  exit 1
fi

echo "Running lint checks..."
npm run lint || exit 1

echo "Running type checks..."
npm run check-types || exit 1

echo "Checking formatting..."
STAGED_FORMAT_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|md)$' || true)
if [ -n "$STAGED_FORMAT_FILES" ]; then
  echo "$STAGED_FORMAT_FILES" | xargs npx prettier --check || exit 1
else
  echo "No staged TypeScript/Markdown files to format-check."
fi

echo "All pre-commit checks passed."
